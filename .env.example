# Copy this file to .env and fill in your values. Never commit .env.

# Gemini API key (used for LLM + Speech-to-Text)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# edge-tts voice for Hinglish output (Hindi neural voices handle code-mixing well)
TTS_VOICE=hi-IN-MadhurNeural

# Debug mode: true for verbose console logging during development
DEBUG=false
